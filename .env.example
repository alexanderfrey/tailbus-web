# Tailbus coordinator API URL (required)
NEXT_PUBLIC_COORD_URL=https://coord.tailbus.co

# Postgres connection (required for waitlist)
# DB_HOST=your-host
# DB_NAME=defaultdb
# DB_USER=tsdbadmin
# DB_PASSWORD=your-password
# DB_PORT=5432
# DB_SSL=true

# Google Analytics measurement ID (optional — omit to disable tracking)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Webhook URL for waitlist signups (optional — Discord or Slack webhook)
# WAITLIST_WEBHOOK_URL=https://discord.com/api/webhooks/...
